---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum">
  <div class="mx-auto max-w-2xl px-6 py-16">
    <h1 class="font-mono text-2xl font-bold mb-8">Impressum</h1>

    <section class="mb-8">
      <h2 class="font-mono text-sm uppercase tracking-widest text-[var(--color-text-muted)] mb-3">Angaben gemäß § 5 TMG</h2>
      <p class="leading-relaxed">
        Michael Schempp<br />
        Breitenfeldstr. 2<br />
        79341 Kenzingen
      </p>
    </section>

    <section class="mb-8">
      <h2 class="font-mono text-sm uppercase tracking-widest text-[var(--color-text-muted)] mb-3">Kontakt</h2>
      <p>
        E-Mail: <a href="mailto:contact@michaelschempp.de" class="text-[var(--color-pro)] hover:underline">contact@michaelschempp.de</a>
      </p>
    </section>

    <section>
      <h2 class="font-mono text-sm uppercase tracking-widest text-[var(--color-text-muted)] mb-3">Haftung für Inhalte</h2>
      <p class="leading-relaxed text-[var(--color-text-muted)]">
        Als Diensteanbieter bin ich gemäß § 7 Abs. 1 TMG für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich. Nach §§ 8 bis 10 TMG bin ich als Diensteanbieter jedoch nicht verpflichtet, übermittelte oder gespeicherte fremde Informationen zu überwachen oder nach Umständen zu forschen, die auf eine rechtswidrige Tätigkeit hinweisen.
      </p>
    </section>
  </div>
</BaseLayout>
