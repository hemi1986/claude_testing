---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLang, t, getLocalePath, type Lang } from '@i18n';
import { getCV } from '@content/utils';

const lang = getLang(Astro.url) as Lang;
const tr = t(lang);
const base = getLocalePath(lang, '');
const cv = await getCV(lang);
---

<BaseLayout title={tr.pro.cvTitle} section="pro">
  <div class="max-w-4xl mx-auto px-4 py-16">

    <div class="mb-12">
      <p class="font-mono text-sm text-[var(--color-pro)] mb-4 tracking-widest">PRO://cv</p>
      <h1 class="text-4xl font-bold mb-4">{tr.pro.cvTitle}</h1>
      <p class="text-[var(--color-text-muted)]">{cv.data.subtitle}</p>
    </div>

    <div class="mb-12 p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] flex items-center gap-3">
      <span class="font-mono text-xs text-[var(--color-text-muted)]">📄</span>
      <span class="text-sm text-[var(--color-text-muted)]">
        {tr.pro.cvPdfHint} <a href={`${base}/pro/contact`} class="text-[var(--color-pro)] hover:underline">{tr.pro.cvPdfLink}</a>
      </span>
    </div>

    <section class="mb-12">
      <h2 class="font-mono text-xs text-[var(--color-text-muted)] tracking-widest uppercase mb-8">{tr.pro.cvExperienceTitle}</h2>
      <div class="space-y-8">
        {cv.data.experience.map(job => (
          <div class="relative pl-6 border-l border-[var(--color-border)]">
            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full border-2 border-[var(--color-pro)] bg-[var(--color-bg)]"></div>
            <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
              <div>
                <h3 class="font-bold text-lg">{job.role}</h3>
                <p class="text-[var(--color-pro)] font-medium">{job.company}</p>
              </div>
              <span class="font-mono text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-surface)] px-2 py-1 rounded border border-[var(--color-border)]">
                {job.period}
              </span>
            </div>
            <div class="text-sm text-[var(--color-text-muted)] mb-3 space-y-3">
              {job.description.split('\n\n').map(para => (
                <p class="leading-relaxed">{para}</p>
              ))}
            </div>
            <div class="flex flex-wrap gap-2">
              {job.tags.map(tag => (
                <span class="font-mono text-xs px-2 py-0.5 rounded bg-[var(--color-pro-dim)] text-[var(--color-pro)]">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-mono text-xs text-[var(--color-text-muted)] tracking-widest uppercase mb-6">{tr.pro.cvSkillsTitle}</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {cv.data.skills.map(skill => (
          <div class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)]">
            <div class="font-mono text-xs text-[var(--color-pro)] mb-1">{skill.category}</div>
            <div class="text-sm text-[var(--color-text-muted)]">{skill.items}</div>
          </div>
        ))}
      </div>
    </section>

    {cv.data.education && cv.data.education.length > 0 && (
      <section class="mb-12">
        <h2 class="font-mono text-xs text-[var(--color-text-muted)] tracking-widest uppercase mb-6">{tr.pro.cvEducationTitle}</h2>
        <div class="space-y-3">
          {cv.data.education.map(item => (
            <div class="flex flex-wrap items-baseline justify-between gap-2 py-2 border-b border-[var(--color-border)] last:border-0">
              <div>
                <span class="text-sm font-medium">{item.degree}</span>
                <span class="text-sm text-[var(--color-text-muted)] ml-2">— {item.institution}</span>
              </div>
              {item.year && (
                <span class="font-mono text-xs text-[var(--color-text-muted)]">{item.year}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
