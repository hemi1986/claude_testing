---
import BaseLayout from '@layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getLang, t, getLocalePath, type Lang } from '@i18n';
import { getAllSlugs, getProjectBySlug } from '@content/utils';

export async function getStaticPaths() {
  const slugs = await getAllSlugs('pro', 'projects');
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const lang = getLang(Astro.url) as Lang;
const tr = t(lang);
const base = getLocalePath(lang, '');

const project = await getProjectBySlug('pro', slug!, lang);
if (!project) return Astro.redirect(`${base}/pro/projects`);

const { Content } = await render(project as any);
---

<BaseLayout title={project.data.title} section="pro">
  <div class="max-w-4xl mx-auto px-4 py-16">

    <a href={`${base}/pro/projects`} class="font-mono text-xs text-[var(--color-text-muted)] hover:text-[var(--color-pro)] transition-colors mb-8 inline-block">
      {tr.pro.backToProjects}
    </a>

    <div class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="font-mono text-xs px-2 py-1 rounded bg-[var(--color-pro-dim)] text-[var(--color-pro)]">
          {tr.common.status[project.data.status]}
        </span>
        <span class="font-mono text-xs text-[var(--color-text-muted)]">
          {project.data.date.toLocaleDateString(tr.common.dateLocale, { year: 'numeric', month: 'long' })}
        </span>
      </div>
      <h1 class="text-4xl font-bold mb-4">{project.data.title}</h1>
      <p class="text-xl text-[var(--color-text-muted)]">{project.data.description}</p>
    </div>

    {project.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10 pb-10 border-b border-[var(--color-border)]">
        {project.data.tags.map(tag => (
          <span class="font-mono text-xs px-2 py-0.5 rounded bg-[var(--color-pro-dim)] text-[var(--color-pro)]">{tag}</span>
        ))}
      </div>
    )}

    <article class="prose"><Content /></article>

  </div>
</BaseLayout>
