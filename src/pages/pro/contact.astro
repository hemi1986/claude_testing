---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLang, t, type Lang } from '@i18n';

const lang = getLang(Astro.url) as Lang;
const tr = t(lang);
---

<BaseLayout title={tr.pro.contactTitle} section="pro">
  <div class="max-w-2xl mx-auto px-4 py-16">

    <div class="mb-12">
      <p class="font-mono text-sm text-[var(--color-pro)] mb-4 tracking-widest">PRO://contact</p>
      <h1 class="text-4xl font-bold mb-4">{tr.pro.contactTitle}</h1>
      <p class="text-[var(--color-text-muted)]">{tr.pro.contactDesc}</p>
    </div>

    <div class="grid gap-4 mb-12">
      {[
        { label: 'Email', value: 'hallo@michaelschempp.de', href: 'mailto:hallo@michaelschempp.de', icon: '✉️' },
        { label: 'LinkedIn', value: 'linkedin.com/in/michaelschempp', href: '#', icon: '💼' },
        { label: 'GitHub', value: 'github.com/michaelschempp', href: '#', icon: '🐙' },
      ].map(link => (
        <a href={link.href} class="group flex items-center gap-4 p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] hover:border-[var(--color-pro)] transition-all">
          <span class="text-xl">{link.icon}</span>
          <div>
            <div class="font-mono text-xs text-[var(--color-text-muted)] mb-0.5">{link.label}</div>
            <div class="text-sm group-hover:text-[var(--color-pro)] transition-colors">{link.value}</div>
          </div>
        </a>
      ))}
    </div>

    <form class="space-y-4" name="contact" method="POST">
      <div>
        <label class="font-mono text-xs text-[var(--color-text-muted)] block mb-2">{tr.pro.contactFormName}</label>
        <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text)] focus:outline-none focus:border-[var(--color-pro)] transition-colors" />
      </div>
      <div>
        <label class="font-mono text-xs text-[var(--color-text-muted)] block mb-2">{tr.pro.contactFormEmail}</label>
        <input type="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text)] focus:outline-none focus:border-[var(--color-pro)] transition-colors" />
      </div>
      <div>
        <label class="font-mono text-xs text-[var(--color-text-muted)] block mb-2">{tr.pro.contactFormMessage}</label>
        <textarea name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] text-[var(--color-text)] focus:outline-none focus:border-[var(--color-pro)] transition-colors resize-none"></textarea>
      </div>
      <button type="submit" class="w-full py-3 rounded-lg font-mono font-bold text-sm text-[var(--color-bg)] bg-[var(--color-pro)] hover:opacity-90 transition-opacity">
        {tr.pro.contactFormSend}
      </button>
    </form>

  </div>
</BaseLayout>
