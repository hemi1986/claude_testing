---
import BaseLayout from '@layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getLang, t, getLocalePath, type Lang } from '@i18n';
import { getAllSlugs, getBlogPostBySlug } from '@content/utils';

export async function getStaticPaths() {
  const slugs = await getAllSlugs('pro', 'blog');
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const lang = getLang(Astro.url) as Lang;
const tr = t(lang);
const base = getLocalePath(lang, '');

const post = await getBlogPostBySlug('pro', slug!, lang);
if (!post) return Astro.redirect(`${base}/pro/blog`);

const { Content } = await render(post as any);
---

<BaseLayout title={post.data.title} section="pro">
  <div class="max-w-4xl mx-auto px-4 py-16">

    <a href={`${base}/pro/blog`} class="font-mono text-xs text-[var(--color-text-muted)] hover:text-[var(--color-pro)] transition-colors mb-8 inline-block">
      {tr.pro.backToBlog}
    </a>

    <header class="mb-10 pb-10 border-b border-[var(--color-border)]">
      <p class="font-mono text-xs text-[var(--color-text-muted)] mb-4">
        {post.data.date.toLocaleDateString(tr.common.dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
      <p class="text-xl text-[var(--color-text-muted)]">{post.data.description}</p>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {post.data.tags.map(tag => (
            <span class="font-mono text-xs px-2 py-0.5 rounded bg-[var(--color-pro-dim)] text-[var(--color-pro)]">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <article class="prose"><Content /></article>

  </div>
</BaseLayout>
