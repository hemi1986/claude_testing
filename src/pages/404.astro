---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Seite nicht gefunden">
  <div class="max-w-2xl mx-auto px-6 py-32 text-center font-mono">
    <div class="text-8xl font-bold text-[var(--color-border)] mb-6">404</div>
    <h1 class="text-2xl font-bold mb-4">Seite nicht gefunden</h1>
    <p class="text-[var(--color-text-muted)] mb-12">
      Diese Seite existiert nicht oder wurde verschoben.
    </p>
    <a href="/" class="text-[var(--color-pro)] hover:underline">← Zurück zur Startseite</a>
  </div>
</BaseLayout>
