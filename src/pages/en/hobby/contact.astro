---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLang, t, type Lang } from '@i18n';

const lang = getLang(Astro.url) as Lang;
const tr = t(lang);
---

<BaseLayout title={tr.hobby.contactTitle} section="hobby">
  <div class="max-w-4xl mx-auto px-4 py-16">

    <div class="mb-12">
      <p class="font-mono text-sm text-[var(--color-hobby)] mb-4 tracking-widest">PLAY://contact</p>
      <h1 class="text-4xl font-bold mb-4">{tr.hobby.contactTitle}</h1>
      <p class="text-[var(--color-text-muted)]">{tr.hobby.contactDesc}</p>
    </div>

    <div class="grid gap-4">
      {[
        { label: 'Email', value: 'hallo@michaelschempp.de', href: 'mailto:hallo@michaelschempp.de', icon: '✉️' },
        { label: 'Flippermarkt.de', value: 'flippermarkt.de', href: 'https://www.flippermarkt.de', icon: '🎯' },
      ].map(link => (
        <a href={link.href} class="group flex items-center gap-4 p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] hover:border-[var(--color-hobby)] transition-all">
          <span class="text-xl">{link.icon}</span>
          <div>
            <div class="font-mono text-xs text-[var(--color-text-muted)] mb-0.5">{link.label}</div>
            <div class="text-sm group-hover:text-[var(--color-hobby)] transition-colors">{link.value}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
