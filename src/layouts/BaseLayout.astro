---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  section?: 'pro' | 'hobby';
}

const { title, description = 'Michael Schempp — Software Architect & Pinball Nerd', section } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Michael Schempp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline>
      // Prevent flash of wrong theme
      const theme = localStorage.getItem('theme') ?? 'dark';
      if (theme === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body>
    <Nav section={section} />
    <main>
      <slot />
    </main>
    <footer class="mt-24 border-t border-[var(--color-border)] py-8 text-center text-sm text-[var(--color-text-muted)] font-mono">
      <span>© {new Date().getFullYear()} Michael Schempp</span>
      <span class="mx-2 opacity-30">·</span>
      <span>michaelschempp.de</span>
    </footer>
  </body>
</html>
