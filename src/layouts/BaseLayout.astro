---
import Nav from '../components/Nav.astro';
import '../styles/global.css';
import { getLang } from '../i18n';

interface Props {
  title: string;
  description?: string;
  section?: 'pro' | 'hobby';
}

const { title, description = 'Michael Schempp — Software Architect & Pinball Nerd', section } = Astro.props;
const lang = getLang(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Michael Schempp</title>
    <meta property="og:title" content={`${title} — Michael Schempp`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'de_DE'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline>
      // Prevent flash of wrong theme
      const theme = localStorage.getItem('theme') ?? 'dark';
      if (theme === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body>
    <Nav section={section} />
    <main>
      <slot />
    </main>
    <footer class="mt-24 border-t border-[var(--color-border)] py-8 text-center text-sm text-[var(--color-text-muted)] font-mono">
      <span>© {new Date().getFullYear()} Michael Schempp</span>
      <span class="mx-2 opacity-30">·</span>
      <span>michaelschempp.de</span>
      <span class="mx-2 opacity-30">·</span>
      <a href="/impressum" class="hover:text-[var(--color-text)] transition-colors">Impressum</a>
      <span class="mx-2 opacity-30">·</span>
      <a href="/datenschutz" class="hover:text-[var(--color-text)] transition-colors">Datenschutz</a>
    </footer>
  </body>
</html>
